<UserControl x:Class="GasStationIS.Views.UserControls.ReportsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GasStationIS.ViewModels">

    <UserControl.DataContext>
        <vm:ReportsViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Header + period filter -->
            <DockPanel Margin="0,0,0,20">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="С:" FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding From}"
                                Style="{StaticResource ModernDatePicker}"
                                Width="140" Margin="0,0,12,0"/>
                    <TextBlock Text="По:" FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding To}"
                                Style="{StaticResource ModernDatePicker}"
                                Width="140" Margin="0,0,12,0"/>
                    <Button Content="📊  Сформировать"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding GenerateCommand}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Отчёты"/>
                    <TextBlock Style="{StaticResource SectionSubtitle}"
                               Text="{Binding StatusMessage, FallbackValue='Выберите период и нажмите «Сформировать»'}"/>
                </StackPanel>
            </DockPanel>

            <!-- Summary cards row -->
            <UniformGrid Columns="5" Margin="0,0,0,24">

                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="ВЫРУЧКА ТОПЛИВО" Margin="0,0,0,8"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBlue}"
                                   Text="{Binding FuelRevenue, StringFormat='{}{0:N0} ₽'}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="ВЫРУЧКА МАГАЗИН" Margin="0,0,0,8"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreen}"
                                   Text="{Binding ShopRevenue, StringFormat='{}{0:N0} ₽'}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="ИТОГО ВЫРУЧКА" Margin="0,0,0,8"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Text="{Binding TotalRevenue, StringFormat='{}{0:N0} ₽'}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="ПРОДАЖ ТОПЛИВА" Margin="0,0,0,8"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentOrange}"
                                   Text="{Binding FuelCount}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormLabel}" Text="ЧЕКОВ МАГАЗИНА" Margin="0,0,0,8"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Card4Icon}"
                                   Text="{Binding ShopCount}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Two column: fuel by type + stock -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Продажи по видам топлива -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                                   Text="Продажи по видам топлива" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding FuelSalesReport}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  RowStyle="{StaticResource ModernDataGridRow}"
                                  CellStyle="{StaticResource ModernDataGridCell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Топливо"    Binding="{Binding Label}"                            Width="*"/>
                                <DataGridTextColumn Header="Продано, л" Binding="{Binding Detail}"                           Width="100"/>
                                <DataGridTextColumn Header="Выручка, ₽" Binding="{Binding Value, StringFormat='{}{0:N2}'}"  Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Остатки топлива -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                                   Text="Остатки топлива" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding FuelStockReport}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  RowStyle="{StaticResource ModernDataGridRow}"
                                  CellStyle="{StaticResource ModernDataGridCell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Топливо"    Binding="{Binding Label}"                           Width="*"/>
                                <DataGridTextColumn Header="Остаток, л" Binding="{Binding Value, StringFormat='{}{0:N0}'}" Width="110"/>
                                <DataGridTextColumn Header="Ёмкость"    Binding="{Binding Detail}"                          Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Daily revenue table -->
            <Border Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                               Text="Выручка по дням" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding DailyRevenue}"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              CellStyle="{StaticResource ModernDataGridCell}"
                              MaxHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата"       Binding="{Binding Label}"                           Width="150"/>
                            <DataGridTextColumn Header="Выручка, ₽" Binding="{Binding Value, StringFormat='{}{0:N2}'}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

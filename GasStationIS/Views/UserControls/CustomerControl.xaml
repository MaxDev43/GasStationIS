<UserControl x:Class="GasStationIS.Views.UserControls.CustomerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GasStationIS.ViewModels">

    <UserControl.DataContext>
        <vm:CustomerViewModel/>
    </UserControl.DataContext>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Content="↻  Обновить"
                    Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}"/>
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Клиенты"/>
                <TextBlock Style="{StaticResource SectionSubtitle}" Text="База клиентов и программа лояльности"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <!-- Customer grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                               Text="Клиентская база" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"             Binding="{Binding FullName}"                              Width="*"/>
                            <DataGridTextColumn Header="Телефон"         Binding="{Binding Phone}"                                 Width="130"/>
                            <DataGridTextColumn Header="Авто"            Binding="{Binding CarNumber}"                             Width="100"/>
                            <DataGridTextColumn Header="Баллы"           Binding="{Binding LoyaltyPoints, StringFormat='{}{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="Сумма покупок"   Binding="{Binding TotalSpent,    StringFormat='{}{0:N2} ₽'}" Width="130"/>
                            <DataGridTextColumn Header="Уровень"         Binding="{Binding LoyaltyLevel}"                          Width="100"/>
                            <DataGridTextColumn Header="Регистрация"     Binding="{Binding RegistrationDate}"                      Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Form panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H3}" Text="Карточка клиента" Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="ФИО *"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Телефон"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="E-Mail"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Гос. номер авто"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding CarNumber, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <!-- Selected customer info -->
                    <Border Background="{StaticResource PrimaryLight}" CornerRadius="10"
                            Padding="14,12" Margin="0,0,0,16"
                            Visibility="{Binding SelectedCustomer, Converter={StaticResource NotNullOrEmpty}}">
                        <StackPanel>
                            <TextBlock Text="Данные клиента"
                                       FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,6"/>
                            <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextPrimary}">
                                <Run Text="Баллы: "/>
                                <Run Text="{Binding SelectedCustomer.LoyaltyPoints, StringFormat='{}{0:N0}'}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextPrimary}">
                                <Run Text="Куплено: "/>
                                <Run Text="{Binding SelectedCustomer.TotalSpent, StringFormat='{}{0:N2} ₽'}"/>
                            </TextBlock>
                            <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource AccentOrange}">
                                <Run Text="Уровень: "/>
                                <Run Text="{Binding SelectedCustomer.LoyaltyLevel}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <UniformGrid Columns="2" Rows="1">
                        <Button Content="➕  Добавить"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddCommand}"
                                Margin="0,0,4,0"/>
                        <Button Content="💾  Обновить"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding UpdateCommand}"
                                Margin="4,0,0,0"/>
                    </UniformGrid>
                    <Button Content="🗑  Удалить клиента"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteCommand}"
                            Margin="0,8,0,0"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusMessage}"
                               TextWrapping="Wrap" Margin="0,10,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NotNullOrEmpty}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GasStationIS.Views.UserControls.FuelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GasStationIS.ViewModels">

    <UserControl.DataContext>
        <vm:FuelViewModel/>
    </UserControl.DataContext>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Content="↻  Обновить"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding RefreshCommand}"/>
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Топливо"/>
                <TextBlock Style="{StaticResource SectionSubtitle}"
                           Text="Управление видами топлива, ценами и остатками"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Fuel grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                               Text="Виды топлива" Margin="0,0,0,16"/>
                    <DataGrid ItemsSource="{Binding Fuels}"
                              SelectedItem="{Binding SelectedFuel}"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Вид топлива"   Binding="{Binding Name}"                                          Width="100"/>
                            <DataGridTextColumn Header="Цена, руб/л"   Binding="{Binding PricePerLiter, StringFormat='{}{0:F2}'}"        Width="110"/>
                            <DataGridTextColumn Header="Остаток, л"    Binding="{Binding StockLiters, StringFormat='{}{0:N0}'}"          Width="110"/>
                            <DataGridTextColumn Header="Ёмкость, л"    Binding="{Binding TankCapacity, StringFormat='{}{0:N0}'}"         Width="110"/>
                            <DataGridTextColumn Header="Заполненность" Binding="{Binding StockPercent, StringFormat='{}{0:F1} %'}"       Width="115"/>
                            <DataGridTextColumn Header="Статус"        Binding="{Binding StockStatus}"                                   Width="*"/>
                        </DataGrid.Columns>
                        <!-- Custom row: colored level bar under each row -->
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource FuelBarTrack}" Margin="8,2,8,6">
                                    <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                            Background="{Binding StockPercent, Converter={StaticResource FuelLevelToColor}}"
                                            Width="{Binding StockPercent, Converter={StaticResource FuelLevelToWidth}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.RowDetailsVisibilityMode>Visible</DataGrid.RowDetailsVisibilityMode>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right: Edit panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H3}" Text="Изменить цену" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource BodyText}"
                               Text="Выберите топливо в таблице и введите новую цену."
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Выбранное топливо"/>
                    <Border Background="{StaticResource AppBg}" CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
                        <TextBlock FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBlue}"
                                   Text="{Binding SelectedFuel.Name, FallbackValue='(не выбрано)'}"/>
                    </Border>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Текущая цена, руб/л"/>
                    <Border Background="{StaticResource AppBg}" CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
                        <TextBlock FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Text="{Binding SelectedFuel.PricePerLiter, StringFormat='{}{0:F2} руб/л', FallbackValue='—'}"/>
                    </Border>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Новая цена, руб/л"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding NewPriceText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20"/>

                    <Button Content="💾  Сохранить цену"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SavePriceCommand}"/>

                    <!-- Status -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusMessage}"
                               TextWrapping="Wrap" Margin="0,10,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NotNullOrEmpty}}"/>

                    <Separator Style="{StaticResource Divider}" Margin="0,20"/>

                    <!-- Stock levels mini cards -->
                    <TextBlock Style="{StaticResource H3}" Text="Уровни резервуаров" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding Fuels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource AppBg}" CornerRadius="8"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                                       Foreground="{Binding StockPercent, Converter={StaticResource FuelLevelToColor}}"
                                                       Text="{Binding StockPercent, StringFormat='{}{0:F0}%'}"/>
                                            <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       Text="{Binding Name}"/>
                                        </DockPanel>
                                        <Border Style="{StaticResource FuelBarTrack}" Margin="0,4,0,0">
                                            <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                    Background="{Binding StockPercent, Converter={StaticResource FuelLevelToColor}}"
                                                    Width="{Binding StockPercent, Converter={StaticResource FuelLevelToWidth}}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GasStationIS.Views.UserControls.EmployeeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GasStationIS.ViewModels">

    <UserControl.DataContext>
        <vm:EmployeeViewModel/>
    </UserControl.DataContext>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Content="↻  Обновить"
                    Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}"/>
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="Сотрудники"/>
                <TextBlock Style="{StaticResource SectionSubtitle}" Text="Управление персоналом и правами доступа"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Employee grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                               Text="Список сотрудников" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee}"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"         Binding="{Binding FullName}"  Width="*"/>
                            <DataGridTextColumn Header="Роль"        Binding="{Binding Role}"      Width="130"/>
                            <DataGridTextColumn Header="Логин"       Binding="{Binding Login}"     Width="110"/>
                            <DataGridTextColumn Header="Телефон"     Binding="{Binding Phone}"     Width="130"/>
                            <DataGridTextColumn Header="Принят"      Binding="{Binding HireDate}"  Width="100"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}"  Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H3}" Text="Карточка сотрудника" Margin="0,0,0,16"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="ФИО *"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Роль"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding Roles}"
                                  SelectedItem="{Binding Role}"
                                  Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Логин *"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Телефон"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Style="{StaticResource FormLabel}" Text="Дата приёма"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding HireDate, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <UniformGrid Columns="2" Rows="1">
                            <Button Content="➕  Добавить"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddCommand}" Margin="0,0,4,0"/>
                            <Button Content="💾  Обновить"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding UpdateCommand}" Margin="4,0,0,0"/>
                        </UniformGrid>

                        <Separator Style="{StaticResource Divider}" Margin="0,16"/>

                        <!-- Change password section -->
                        <TextBlock Style="{StaticResource H3}" Text="Смена пароля" Margin="0,0,0,10"/>
                        <TextBlock Style="{StaticResource FormLabel}" Text="Новый пароль"/>
                        <PasswordBox x:Name="NewPwdBox"
                                     Style="{StaticResource ModernPasswordBox}"
                                     PasswordChanged="NewPwdBox_PasswordChanged"
                                     Margin="0,0,0,10"/>
                        <Button Content="🔑  Изменить пароль"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ChangePasswordCommand}"
                                CommandParameter="{Binding ElementName=NewPwdBox, Path=Password}"/>

                        <Separator Style="{StaticResource Divider}" Margin="0,16"/>

                        <Button Content="⛔  Активировать / Деактивировать"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeactivateCommand}"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource StatusMessage}"
                                   TextWrapping="Wrap" Margin="0,10,0,0"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource NotNullOrEmpty}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

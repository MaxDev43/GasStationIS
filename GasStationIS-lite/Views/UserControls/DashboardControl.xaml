<UserControl x:Class="GasStationIS.Views.UserControls.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GasStationIS.ViewModels">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,24">

            <!-- Page header -->
            <DockPanel Margin="0,0,0,24">
                <Button DockPanel.Dock="Right"
                        Content="↻  Обновить"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}"/>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Главная"/>
                    <TextBlock Style="{StaticResource SectionSubtitle}" Text="Сводка показателей АЗС за сегодня" Margin="0"/>
                </StackPanel>
            </DockPanel>

            <!-- ── Stat Cards ────────────────────────────────────────── -->
            <UniformGrid Columns="4" Margin="0,0,0,24">

                <!-- Card: Выручка топливо -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="44" Height="44" CornerRadius="10"
                                Background="{StaticResource Card1Bg}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Viewbox Width="22" Height="22">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource Card1Icon}"
                                          Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Row="1" Style="{StaticResource ValueText}"
                                   Text="{Binding TodayFuelRevenue, StringFormat='{}{0:N0} ₽'}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource BodyText}"
                                   Text="Выручка (топливо)" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- Card: Клиентов в базе -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="44" Height="44" CornerRadius="10"
                Background="{StaticResource Card2Bg}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Viewbox Width="22" Height="22">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource Card2Icon}"
                          Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Row="1" Style="{StaticResource ValueText}"
                   Text="{Binding TotalCustomers}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource BodyText}"
                   Text="Клиентов в базе" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- Card: Продаж топлива -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="44" Height="44" CornerRadius="10"
                                Background="{StaticResource Card3Bg}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Viewbox Width="22" Height="22">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource Card3Icon}"
                                          Data="M3 22h10V3H3v19zm2-17h6v6H5V5zm11 2l-1.5 1.5V10a2 2 0 012 2v7h-1v2h2v-2h1v-7a2 2 0 012-2V8.5L19.5 7z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Row="1" Style="{StaticResource ValueText}"
                                   Text="{Binding TodayFuelCount}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource BodyText}"
                                   Text="Продаж топлива" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- Card: Сотрудники -->
                <Border Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="44" Height="44" CornerRadius="10"
                                Background="{StaticResource Card4Bg}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Viewbox Width="22" Height="22">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{StaticResource Card4Icon}"
                                          Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Row="1" Style="{StaticResource ValueText}"
                                   Text="{Binding ActiveEmployees}"/>
                        <TextBlock Grid.Row="2" Style="{StaticResource BodyText}"
                                   Text="Активных сотрудников" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

            </UniformGrid>

            <!-- ── Two column layout ─────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Recent sales -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource H3}"
                                   Text="Последние продажи топлива" Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding RecentSales}"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  RowStyle="{StaticResource ModernDataGridRow}"
                                  CellStyle="{StaticResource ModernDataGridCell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата/Время"  Binding="{Binding SaleDatetime}" Width="140"/>
                                <DataGridTextColumn Header="Топливо"     Binding="{Binding FuelTypeName}" Width="80"/>
                                <DataGridTextColumn Header="Литры"       Binding="{Binding Liters, StringFormat='{}{0:F1} л'}" Width="80"/>
                                <DataGridTextColumn Header="Сумма"       Binding="{Binding TotalAmount, StringFormat='{}{0:N2} ₽'}" Width="110"/>
                                <DataGridTextColumn Header="Оплата"      Binding="{Binding PaymentMethod}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Fuel levels -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H3}" Text="Остатки топлива" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding FuelLevels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding StockLiters, StringFormat='{}{0:N0} л'}"
                                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{Binding StockPercent, Converter={StaticResource FuelLevelToColor}}"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="Segoe UI" FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                        </DockPanel>
                                        <!-- Progress bar track -->
                                        <Border Style="{StaticResource FuelBarTrack}">
                                            <Border HorizontalAlignment="Left"
                                                    Background="{Binding StockPercent, Converter={StaticResource FuelLevelToColor}}"
                                                    CornerRadius="4" Height="8"
                                                    Width="{Binding StockPercent, Converter={StaticResource FuelLevelToWidth}}"/>
                                        </Border>
                                        <TextBlock Text="{Binding StockStatus}"
                                                   FontFamily="Segoe UI" FontSize="10"
                                                   Foreground="{Binding StockPercent, Converter={StaticResource FuelLevelToColor}}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
